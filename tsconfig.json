{
    "compilerOptions": {
        "noEmit": true,
        "strict": true,
        "target": "ESNext",
        "lib": ["ES2025", "DOM", "DOM.Iterable"],
        "allowJs": true,
        "jsx": "preserve",
        "esModuleInterop": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "forceConsistentCasingInFileNames": true,
        "useUnknownInCatchVariables": true,
        "noImplicitOverride": true,
        "verbatimModuleSyntax": true,
        "paths": {
            "test/*": ["./test/*"],
            "~/*": ["./src/*"]
        },
        "types": ["node"]
    },
    "include": ["src", "test"]
}
